generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- IDENTITY & AUTH ---
enum Role {
  ADMIN
  USER
}

model User {
  id            String         @id @default(uuid())
  username      String         @unique
  email         String         @unique
  password      String?        // Nullable สำหรับ Google Login
  nickname      String
  role          Role           @default(USER)
  avatarUrl     String?
  isActive      Boolean        @default(true)
  
  // Social Login
  provider      String         @default("local")
  googleId      String?        @unique

  lastLogin     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
  posts         Post[]         @relation("PostAuthor")
  approvedPosts Post[]         @relation("PostApprover")
  comments      Comment[]
  documents     Document[]

  profile      Profile?      
  educations   Education[]   
  projects     Project[]     
  interests    Interest[]
  experiences  Experience[]

  albums    Album[]  // อัลบั้มที่สร้าง
  photos    Photo[]  // รูปภาพที่อัปโหลด

  @@map("users")
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceInfo String?
  ipAddress  String?
  isRevoked  Boolean  @default(false)
  expiryDate DateTime
  createdAt  DateTime @default(now())

  @@index([token])
  @@map("refresh_tokens")
}

// --- BLOG & CONTENT ---
enum PostStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
}

model Category {
  id    String @id @default(uuid())
  name  String @unique
  slug  String @unique
  posts Post[]

  @@map("categories")
}

model Post {
  id           String     @id @default(uuid())
  title        String
  content      String     @db.Text
  thumbnail    String?
  status       PostStatus @default(DRAFT)
  
  // สำหรับรีวิวหนังสือ
  rating       Int?       
  bookAuthor   String?

  categoryId   String
  category     Category   @relation(fields: [categoryId], references: [id])
  
  authorId     String
  author       User       @relation("PostAuthor", fields: [authorId], references: [id])
  
  approvedById String?
  approvedBy   User?      @relation("PostApprover", fields: [approvedById], references: [id])
  
  comments     Comment[]
  
  publishedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("posts")
}

model Comment {
  id        String   @id @default(uuid())
  content   String   @db.Text
  
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  parentId  String?
  parent    Comment? @relation("CommentToComment", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentToComment")

  createdAt DateTime @default(now())

  @@map("comments")
}

// --- UTILITY ---
model Document {
  id           String   @id @default(uuid())
  title        String
  filePath     String   
  fileType     String   
  fileSize     Int      
  isTemporary  Boolean  @default(true)
  
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  
  createdAt    DateTime @default(now())

  @@map("documents")
}

// โมเดลใหม่สำหรับข้อมูล Portfolio
model Profile {
  id        String   @id @default(uuid())
  bio       String?  @db.Text
  avatarUrl String?
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("Profile")
}

model Education {
  id          String    @id @default(uuid())
  schoolName  String
  degree      String
  field       String?
  startDate   DateTime
  endDate     DateTime?
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("Education")
}

model Experience {
  id          String    @id @default(uuid())
  title       String    // e.g. Senior Full Stack Developer
  company     String    // e.g. Tech Innovators Inc.
  startDate   DateTime
  endDate     DateTime? // null means Present
  description String?   @db.Text
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("Experience")
}

model Interest {
  id       String @id @default(uuid())
  name     String // เช่น "Calisthenics", "Mystery Novels"
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("Interest")
}

model Project {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  imageUrl    String?
  link        String?  
  createdAt   DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("Project")
}

model Album {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  coverImage  String?  // รูปปกอัลบั้ม
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos      Photo[]

  @@map("albums")
}

model Photo {
  id          String   @id @default(uuid())
  url         String   // ลิงก์รูปภาพ (เช่นจาก Cloudinary หรือ S3)
  caption     String?  @db.Text
  createdAt   DateTime @default(now())

  albumId     String?
  album       Album?   @relation(fields: [albumId], references: [id], onDelete: SetNull)
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("photos")
}