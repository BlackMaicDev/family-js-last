generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- IDENTITY & AUTH ---
enum Role {
  ADMIN
  USER
}

model User {
  id            String         @id @default(uuid())
  username      String         @unique
  email         String         @unique
  password      String?        // Nullable สำหรับ Google Login
  nickname      String
  role          Role           @default(USER)
  avatarUrl     String?
  isActive      Boolean        @default(true)
  
  // Social Login
  provider      String         @default("local")
  googleId      String?        @unique

  lastLogin     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
  posts         Post[]         @relation("PostAuthor")
  approvedPosts Post[]         @relation("PostApprover")
  comments      Comment[]
  documents     Document[]

  profile      Profile?      
  educations   Education[]   
  projects     Project[]     
  interests    Interest[]
  experiences  Experience[]

  albums    Album[]  // อัลบั้มที่สร้าง
  photos    Photo[]  // รูปภาพที่อัปโหลด
  devices   Device[] // อุปกรณ์ IoT
  
  // E-Learning
  examAttempts ExamAttempt[]
  examAnswers  ExamAttemptAnswer[]

  @@map("users")
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceInfo String?
  ipAddress  String?
  isRevoked  Boolean  @default(false)
  expiryDate DateTime
  createdAt  DateTime @default(now())

  @@index([token])
  @@map("refresh_tokens")
}

// --- BLOG & CONTENT ---
enum PostStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
}

model Category {
  id    String @id @default(uuid())
  name  String @unique
  slug  String @unique
  posts Post[]

  @@map("categories")
}

model Post {
  id           String     @id @default(uuid())
  title        String
  content      String     @db.Text
  thumbnail    String?
  status       PostStatus @default(DRAFT)
  
  // สำหรับรีวิวหนังสือ
  rating       Int?       
  bookAuthor   String?

  categoryId   String
  category     Category   @relation(fields: [categoryId], references: [id])
  
  authorId     String
  author       User       @relation("PostAuthor", fields: [authorId], references: [id])
  
  approvedById String?
  approvedBy   User?      @relation("PostApprover", fields: [approvedById], references: [id])
  
  comments     Comment[]
  
  publishedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("posts")
}

model Comment {
  id        String   @id @default(uuid())
  content   String   @db.Text
  
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  parentId  String?
  parent    Comment? @relation("CommentToComment", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentToComment")

  createdAt DateTime @default(now())

  @@map("comments")
}

// --- UTILITY ---
model Document {
  id           String   @id @default(uuid())
  title        String
  filePath     String   
  fileType     String   
  fileSize     Int      
  isTemporary  Boolean  @default(true)
  
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  
  createdAt    DateTime @default(now())

  @@map("documents")
}

// โมเดลใหม่สำหรับข้อมูล Portfolio
model Profile {
  id        String   @id @default(uuid())
  bio       String?  @db.Text
  avatarUrl String?
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("Profile")
}

model Education {
  id          String    @id @default(uuid())
  schoolName  String
  degree      String
  field       String?
  startDate   DateTime
  endDate     DateTime?
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("Education")
}

model Experience {
  id          String    @id @default(uuid())
  title       String    // e.g. Senior Full Stack Developer
  company     String    // e.g. Tech Innovators Inc.
  startDate   DateTime
  endDate     DateTime? // null means Present
  description String?   @db.Text
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("Experience")
}

model Interest {
  id       String @id @default(uuid())
  name     String // เช่น "Calisthenics", "Mystery Novels"
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("Interest")
}

model Project {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  imageUrl    String?
  link        String?  
  createdAt   DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("Project")
}

model Album {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  coverImage  String?  // รูปปกอัลบั้ม
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos      Photo[]

  @@map("albums")
}

model Photo {
  id          String   @id @default(uuid())
  url         String   // ลิงก์รูปภาพ (เช่นจาก Cloudinary หรือ S3)
  caption     String?  @db.Text
  createdAt   DateTime @default(now())

  albumId     String?
  album       Album?   @relation(fields: [albumId], references: [id], onDelete: SetNull)
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("photos")
}

// --- TRACKER FAMILY (IoT) ---
enum AlertType {
  SOS
  LOW_BATTERY
  MOTION_DETECTED
  GEOFENCE_ENTER
  GEOFENCE_EXIT
}

model Device {
  id          String     @id @default(uuid())
  name        String     // เช่น "ลูกน้อย 1"
  simNumber   String?    // เบอร์โทรศัพท์ของ SIM
  macAddress  String?    @unique // MAC/IMEI ไว้รับรองบอร์ด
  battery     Int        @default(100)
  isOnline    Boolean    @default(false)
  lastSeen    DateTime?

  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  locations   Location[]
  alerts      Alert[]
  geofences   Geofence[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("devices")
}

model Location {
  id          String   @id @default(uuid())
  lat         Float
  lng         Float
  speed       Float?

  deviceId    String
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  timestamp   DateTime @default(now())

  @@index([deviceId, timestamp])
  @@map("locations")
}

model Alert {
  id          String    @id @default(uuid())
  type        AlertType
  message     String?
  isResolved  Boolean   @default(false)

  deviceId    String
  device      Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?

  @@map("alerts")
}

model Geofence {
  id          String   @id @default(uuid())
  name        String   // เช่น "โรงเรียน", "บ้าน"
  lat         Float
  lng         Float
  radius      Float    // รัศมีในหน่วยเมตร

  deviceId    String
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("geofences")
}

// --- E-LEARNING & EXAMS ---

model GradeLevel {
  id          String    @id @default(uuid())
  name        String    @unique // e.g., "ม.1", "ม.2", "ป.1", "ปริญญาตรี"
  description String?   @db.Text
  subjects    Subject[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("grade_levels")
}

model ExamType {
  id          String    @id @default(uuid())
  name        String    @unique // e.g., "Pre-test", "Post-test", "TGAT", "TPAT", "A-Level"
  description String?   @db.Text
  exams       Exam[]

  @@map("exam_types")
}

model Subject {
  id           String      @id @default(uuid())
  name         String      // e.g., "คณิตศาสตร์ประยุกต์ 1"
  code         String?     // e.g., "MATH101"
  description  String?     @db.Text
  
  gradeLevelId String?
  gradeLevel   GradeLevel? @relation(fields: [gradeLevelId], references: [id], onDelete: SetNull)
  
  lessons      Lesson[]
  exams        Exam[]

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("subjects")
}

model Lesson {
  id          String   @id @default(uuid())
  title       String
  content     String   @db.Text
  videoUrl    String?
  order       Int      @default(0) // สำหรับเรียงลำดับเนื้อหาในรายวิชา
  
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  exams       Exam[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("lessons")
}

model Exam {
  id          String    @id @default(uuid())
  title       String
  description String?   @db.Text
  timeLimit   Int?      // จับเวลา (นาที) Null = ไม่จำกัดเวลา
  
  subjectId   String
  subject     Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  examTypeId  String?
  examType    ExamType? @relation(fields: [examTypeId], references: [id], onDelete: SetNull)

  lessonId    String?
  lesson      Lesson?   @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  questions   Question[]
  attempts    ExamAttempt[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("exams")
}

model Question {
  id          String         @id @default(uuid())
  text        String         @db.Text
  imageUrl    String?
  explanation String?        @db.Text // คำอธิบายวิธีทำ
  order       Int            @default(0) // ลำดับข้อ
  
  examId      String
  exam        Exam           @relation(fields: [examId], references: [id], onDelete: Cascade)

  options     AnswerOption[]
  attemptAnswers ExamAttemptAnswer[]

  @@map("questions")
}

model AnswerOption {
  id          String   @id @default(uuid())
  text        String
  isCorrect   Boolean  @default(false)
  
  questionId  String
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("answer_options")
}

model ExamAttempt {
  id          String   @id @default(uuid())
  score       Float    @default(0)
  totalScore  Float    @default(0)
  startTime   DateTime @default(now())
  endTime     DateTime?
  status      String   @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED
  
  examId      String
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  answers     ExamAttemptAnswer[]

  @@map("exam_attempts")
}

model ExamAttemptAnswer {
  id              String       @id @default(uuid())
  
  attemptId       String
  attempt         ExamAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  questionId      String
  question        Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)

  selectedOptionId String?     // Null means no answer selected
  
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt       DateTime     @default(now())

  @@unique([attemptId, questionId])
  @@map("exam_attempt_answers")
}