# ============================================================
# Family JS - Environment Variables
# ============================================================
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าให้ตรงกับ server จริง
# cp .env.example .env
# ============================================================

# 🔑 JWT Secrets (ควรเป็น string ยาวๆ สุ่มขึ้นมา)
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this

# 🌍 URL ของ Frontend และ API
# --- PRODUCTION ---
FRONTEND_URL=https://family-js.com
NEXT_PUBLIC_API_URL=https://api.family-js.com

# --- LOCAL DEV ---
# FRONTEND_URL=http://localhost:3001
# NEXT_PUBLIC_API_URL=http://localhost:3000
